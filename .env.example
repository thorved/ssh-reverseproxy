# Copy this file to .env and adjust values.
# Values set here override defaults in code.

# Listen address (host:port). If empty, SSH_PORT is used; default :2222
SSH_LISTEN_ADDR=
# Alternatively set only port
SSH_PORT=2222

# Path to persistent SSH server host key (PEM or OpenSSH private key).
# If unset, an ephemeral in-memory ed25519 key is generated each start,
# which will change the host fingerprint and trigger client warnings.
SSH_HOST_KEY_PATH=./hostkey_ed25519

# Mapping file mapping client keys to upstream targets
SSH_MAPPING_FILE=./mapping.json

# known_hosts file used to verify upstream server host keys
# If unset, upstream host key verification is DISABLED (not recommended)
SSH_KNOWN_HOSTS=~/.ssh/known_hosts

# Custom SSH server identification string (banner)
SSH_SERVER_IDENT=SSH-2.0-ssh-reverseproxy

# If true, when an upstream host key is unknown, the proxy will fetch the key
# and append it to SSH_KNOWN_HOSTS, then retry once. Default false.
SSH_ACCEPT_UNKNOWN_UPSTREAM=false
