ENV=development
PORT=8080
HTTP_LISTEN_ADDR=:8080
# Local frontend origin for development. In production, use your public app URL if you want an explicit base.
FRONTEND_BASE_URL=http://localhost:3000

DATABASE_PATH=./data/ssh-reverseproxy.db

SESSION_COOKIE_NAME=sshrp_session
SESSION_TTL=168h
SESSION_SECURE=false
SESSION_SECRET=change-me-in-production

OIDC_ISSUER_URL=https://your-issuer.example.com
OIDC_CLIENT_ID=your-client-id
OIDC_CLIENT_SECRET=your-client-secret
# Local development callback goes through the Next dev server proxy.
# Production same-origin example: https://your-app.example.com/api/auth/oidc/callback
OIDC_REDIRECT_URL=http://localhost:3000/api/auth/oidc/callback
OIDC_SCOPES=openid,profile,email

ADMIN_EMAILS=admin@example.com

SSH_LISTEN_ADDR=:2222
SSH_HOST_KEY_PATH=./data/hostkey_ed25519
SSH_KNOWN_HOSTS=./data/known_hosts
SSH_SERVER_IDENT=SSH-2.0-ssh-reverseproxy
SSH_DIAL_TIMEOUT=15s
SSH_ACCEPT_UNKNOWN_UPSTREAM=false
